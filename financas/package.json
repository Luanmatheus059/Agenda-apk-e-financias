{
  "name": "minhas-financas",
  "version": "1.0.0",
  "description": "Minhas Finanças PWA empacotada como app Android nativo, com leitura de notificações dos bancos",
  "private": true,
  "scripts": {
    "build": "echo 'static www, nothing to build'",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/preferences": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
