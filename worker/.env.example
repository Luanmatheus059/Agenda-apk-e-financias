# Token do bot Telegram — pega no @BotFather (instruções no README)
TELEGRAM_BOT_TOKEN=1234567890:AAEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

# Seu chat ID — descobre mandando msg pro bot e abrindo:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# Watchlist — separe por vírgula. Suporta tickers B3, BTC, ETH, USD-BRL.
WATCHLIST=PETR4,VALE3,ITUB4,BBAS3,MGLU3,WEGE3,B3SA3,BTC,ETH,USD-BRL

# Intervalo entre verificações (em minutos). Padrão 5min (rate-limit safe pra Brapi)
CHECK_INTERVAL_MINUTES=5

# Horário de pregão B3 (não envia notificações fora desse horário em dias úteis)
MARKET_OPEN_HOUR=10
MARKET_CLOSE_HOUR=18

# Ativa notificações fora do horário do mercado (sábado, domingo, madrugada)?
# false = só durante pregão. true = 24/7 verdadeiro.
NOTIFY_24_7=false

# Nível mínimo de setup pra notificar:
# 'low' = todos os setups (sobrevendido, tendência curta, etc)
# 'medium' = só setups fortes (cruz dourada, cruz da morte, RSI extremo)
# 'high' = só cruzamentos críticos
ALERT_LEVEL=medium

# Resumo diário do mercado (envia summary à hora especificada, dia útil)
SEND_DAILY_SUMMARY=true
DAILY_SUMMARY_HOUR=8
